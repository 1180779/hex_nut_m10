# latexmk configuration file

# PDF generation mode
# 0 = disable PDF generation (DVI mode)
# 1 = pdflatex            (pdfTeX)
# 2 = ps2pdf via dvips    (LaTeX → DVI → PS → PDF)
# 3 = dvipdf              (LaTeX → DVI → PDF)
# 4 = lualatex            (LuaTeX)
# 5 = xelatex             (XeTeX)
$pdf_mode = 1;
