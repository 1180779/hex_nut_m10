# Copy this file to ".env" and adjust the paths for your machine.
# The real .env is git-ignored, so machine-specific paths stay out of git.
#
# These are only needed for the Windows OpenCASCADE binary distribution.
# On Linux/macOS (or with vcpkg/conda) leave them unset and CMake will use
# find_package(OpenCASCADE) instead.
#
# Precedence: -D<VAR> on the cmake command line > real env var > .env > defaults.

# Root of the unpacked "opencascade-x.y.z-vcNN-64" folder (contains inc/, win64/).
OpenCASCADE_ROOT=C:/path/to/opencascade-8.0.0-vc14-64

# Root of the matching "3rdparty-vcNN-64" folder (its *.dll files are copied
# next to the built executable).
OpenCASCADE_THIRDPARTY_ROOT=C:/path/to/3rdparty-vc14-64
